  <!-- Copia YgoMasterSettings.exe + .pdb pro install dir após build (mesmo
       padrão dos outros csprojs). Idempotente; no-op se a pasta não existe. -->
  <PropertyGroup>
    <GoatInstallDir>D:\SteamLibrary\steamapps\common\Yu-Gi-Oh!  Master Duel\YgoMasterLE - Goat</GoatInstallDir>
  </PropertyGroup>
  <Target Name="CopyToGoatInstall" AfterTargets="Build"
          Condition="Exists('$(GoatInstallDir)')">
    <!-- Mata a instância rodando antes do copy — senão o exe fica
         locked e o copy falha após 10 retries. Silenciamos stderr
         (2>nul) e ignoramos exit code pra não dar erro quando o
         processo simplesmente não está rodando. -->
    <Exec Command="taskkill /F /IM YgoMasterSettings.exe 2&gt;nul"
          IgnoreExitCode="true" />
    <Copy SourceFiles="$(OutputPath)YgoMasterSettings.exe;$(OutputPath)YgoMasterSettings.pdb"
          DestinationFolder="$(GoatInstallDir)"
          SkipUnchangedFiles="true" />
    <Message Text="[Goat] Copied YgoMasterSettings.exe + .pdb -&gt; $(GoatInstallDir)"
             Importance="high" />
  </Target>
</Project>
